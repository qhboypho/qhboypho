{
  "name": "qhclothes",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:sandbox": "wrangler pages dev dist --ip 0.0.0.0 --port 3000",
    "build": "vite build",
    "preview": "wrangler pages dev dist",
    "deploy": "npm run build && wrangler pages deploy dist",
    "deploy:prod": "npm run build && wrangler pages deploy dist --project-name qhclothes",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "db:migrate:local": "wrangler d1 migrations apply fashion-store-production --local",
    "db:seed": "wrangler d1 execute fashion-store-production --local --file=./migrations/0002_seed.sql",
    "db:reset": "rm -rf .wrangler/state/v3/d1 && npm run db:migrate:local && npm run db:seed",
    "test:payos-local": "node scripts/test-payos-local.mjs",
    "test:zalopay-local": "node scripts/test-zalopay-local.mjs",
    "test:initdb-noop": "node --experimental-strip-types scripts/test-initdb-noop-contract.mjs",
    "check:ui-safety": "node scripts/check-ui-safety.mjs"
  },
  "dependencies": {
    "hono": "^4.12.1",
    "pdf-lib": "^1.17.1"
  },
  "devDependencies": {
    "@hono/vite-build": "^1.2.0",
    "@hono/vite-dev-server": "^0.18.2",
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2",
    "vite": "^6.3.5",
    "wrangler": "^4.4.0"
  }
}
